# secrets.toml.example — Streamlit Community Cloud 배포용 비밀값 템플릿.
#
# 로컬: 이 파일을 `.streamlit/secrets.toml`로 복사해 값을 채우면 st.secrets로 로드됩니다.
#       (secrets.toml 은 .gitignore로 커밋 차단됨)
# 클라우드: Streamlit Cloud 대시보드 > App settings > Secrets 에 아래 내용을 붙여넣습니다.
#
# 앱 소유자는 최소한 Supabase 접속 정보를 여기 두는 것을 권장합니다(인프라 성격).
# LLM 키는 방문자가 사이드바에서 직접 입력하게 하려면 비워둘 수 있습니다.

SUPABASE_URL = "https://your-project-ref.supabase.co"
SUPABASE_SERVICE_KEY = "your-supabase-service-role-key"

# (선택) 소유자가 기본 제공하려는 경우에만
# GEMINI_API_KEY = "..."
# OPENROUTER_API_KEY = "..."
# COHERE_API_KEY = "..."

# (권장) 공개 데모의 문서 업로드 탭 보호
UPLOAD_PASSWORD = "choose-a-strong-password"
