# .env.example — 이 파일을 복사해 `.env`로 만들고 실제 키를 채우세요.
#   cp .env.example .env
# .env 는 .gitignore에 의해 커밋되지 않습니다. 실제 키를 여기(.env.example)에 넣지 마세요.
#
# 앱(Streamlit)에서는 사이드바에서 LLM 키를 직접 입력할 수도 있습니다.
# 우선순위: UI 입력 > st.secrets(Streamlit Cloud) > .env(로컬)

# ── 필수: 벡터 저장소 ─────────────────────────────────
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_KEY=your-supabase-service-role-key

# ── 임베딩·챗 (Gemini) ────────────────────────────────
# 임베딩 기본 Provider는 Gemini(gemini-embedding-001). 문서 적재/질의에 필요.
GEMINI_API_KEY=your-gemini-api-key

# ── 챗 (OpenRouter) ───────────────────────────────────
# 챗 Provider로 OpenRouter를 쓸 때 필요(gpt-4o-mini 등).
OPENROUTER_API_KEY=your-openrouter-api-key

# ── Rerank (Cohere) ───────────────────────────────────
# Advanced/Modular RAG의 재정렬에 필요.
COHERE_API_KEY=your-cohere-api-key

# ── 선택: OpenAI 임베딩 대안 ──────────────────────────
# `--embedding openai` 또는 앱에서 임베딩 Provider를 openai로 선택할 때만 필요.
# OPENAI_API_KEY=your-openai-api-key

# ── 선택: 공개 데모 업로드 보호 ───────────────────────
# 설정하면 문서 업로드 탭에서 이 비밀번호를 요구합니다(공유 DB 오염 방지).
# UPLOAD_PASSWORD=choose-a-strong-password
